# Copy this file to .env and fill in your values.
# The application runs fully WITHOUT an API key (it falls back to the
# built-in offline conversation engine). Add a key only if you want
# live LLM-generated responses.

# OpenAI API key (optional)
OPENAI_API_KEY=

# Model to use when an API key is present
OPENAI_MODEL=gpt-4o-mini

# Path to the SQLite database file
MINDMATE_DB_PATH=data/mindmate.db
